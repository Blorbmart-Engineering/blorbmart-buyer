rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ========================================
    // HELPER FUNCTIONS
    // ========================================
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserId() {
      return request.auth.uid;
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(getUserId())).data.role;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserRole() == 'admin';
    }
    
    function isBuyer() {
      return isSignedIn() && getUserRole() == 'buyer';
    }
    
    function isVendor() {
      return isSignedIn() && getUserRole() == 'vendor';
    }
    
    function isRider() {
      return isSignedIn() && getUserRole() == 'rider';
    }
    
    function isOwner(userId) {
      return isSignedIn() && getUserId() == userId;
    }
    
    function isAccountActive() {
      return get(/databases/$(database)/documents/users/$(getUserId())).data.accountStatus == 'active';
    }
    
    function hasVendorDocument() {
      return exists(/databases/$(database)/documents/vendors/$(getUserId()));
    }
    
    function getVendorData() {
      return get(/databases/$(database)/documents/vendors/$(getUserId())).data;
    }
    
    function storeBelongsToVendor(storeId) {
      return !exists(/databases/$(database)/documents/stores/$(storeId)) || 
             get(/databases/$(database)/documents/stores/$(storeId)).data.vendorId == getUserId();
    }
    
    function vendorOwnsStore(storeId) {
      return exists(/databases/$(database)/documents/stores/$(storeId)) && 
             get(/databases/$(database)/documents/stores/$(storeId)).data.vendorId == getUserId();
    }
    
    function hasBuyerDocument() {
      return exists(/databases/$(database)/documents/buyers/$(getUserId()));
    }
    
    function hasRiderDocument() {
      return exists(/databases/$(database)/documents/riders/$(getUserId()));
    }
    
    // ========================================
    // USERS COLLECTION
    // ========================================
    
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      
      allow create: if isSignedIn() && 
        isOwner(userId) && 
        request.resource.data.uid == getUserId() && 
        request.resource.data.role in ['buyer', 'vendor', 'rider'] && 
        request.resource.data.accountStatus == 'active' && 
        request.resource.data.keys().hasAll(['uid', 'firstName', 'lastName', 'email', 'phone', 'role', 'accountStatus', 'createdAt']) && 
        request.resource.data.isEmailVerified is bool && 
        request.resource.data.isPhoneVerified is bool;
      
      allow update: if isSignedIn() && (
        (isOwner(userId) && 
         request.resource.data.uid == resource.data.uid && 
         request.resource.data.role == resource.data.role && 
         request.resource.data.accountStatus == resource.data.accountStatus
        ) || 
        isAdmin()
      );
      
      allow delete: if isAdmin();
      
      // User Addresses Subcollection
      match /addresses/{addressId} {
        allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
        
        allow create: if isSignedIn() && 
          isOwner(userId) && 
          request.resource.data.keys().hasAll(['name', 'addressLine1', 'city', 'state', 'phone', 'isDefault', 'createdAt']) && 
          request.resource.data.name is string && 
          request.resource.data.addressLine1 is string && 
          request.resource.data.city is string && 
          request.resource.data.state is string && 
          request.resource.data.phone is string && 
          request.resource.data.isDefault is bool;
        
        allow update: if isSignedIn() && (isOwner(userId) || isAdmin());
        
        allow delete: if isSignedIn() && (isOwner(userId) || isAdmin());
      }
      
      // User Wishlist Subcollection
      match /wishlist/{productId} {
        allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
        
        allow create: if isSignedIn() && 
          isOwner(userId) && 
          exists(/databases/$(database)/documents/products/$(productId));
        
        allow delete: if isSignedIn() && isOwner(userId);
      }
    }
    
    // ========================================
    // CARTS COLLECTION
    // ========================================
    
    match /carts/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      
      allow create: if isSignedIn() && 
        isOwner(userId) && 
        request.resource.data.userId == getUserId();
      
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin());
      
      allow delete: if isSignedIn() && (isOwner(userId) || isAdmin());
      
      // Cart Items Subcollection
      match /items/{cartItemId} {
        allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
        
        allow create: if isSignedIn() && 
          isOwner(userId) && 
          isAccountActive() && 
          request.resource.data.quantity > 0 && 
          exists(/databases/$(database)/documents/products/$(request.resource.data.productId));
        
        allow update: if isSignedIn() && 
          isOwner(userId) && 
          isAccountActive() && 
          request.resource.data.quantity > 0;
        
        allow delete: if isSignedIn() && (isOwner(userId) || isAdmin());
      }
    }
    
    // ========================================
    // BUYERS COLLECTION
    // ========================================
    
    match /buyers/{buyerId} {
      allow read: if isSignedIn() && (isOwner(buyerId) || isAdmin());
      
      allow create: if isSignedIn() && 
        isOwner(buyerId) && 
        isBuyer() && 
        request.resource.data.userId == getUserId() && 
        request.resource.data.walletBalance == 0 && 
        request.resource.data.loyaltyPoints == 0 && 
        request.resource.data.totalOrders == 0 && 
        request.resource.data.isBlocked == false;
      
      allow update: if isSignedIn() && (
        (isOwner(buyerId) && 
         isBuyer() && 
         isAccountActive() && 
         request.resource.data.userId == resource.data.userId && 
         request.resource.data.isBlocked == resource.data.isBlocked &&
         // Wallet balance is backend-only — clients can never change it
         request.resource.data.walletBalance == resource.data.walletBalance
        ) || 
        isAdmin()
      );
      
      allow delete: if isAdmin();
      
      // Buyer Addresses Subcollection
      match /addresses/{addressId} {
        allow read: if isSignedIn() && (isOwner(buyerId) || isAdmin());
        
        allow create: if isSignedIn() && 
          isOwner(buyerId) && 
          isBuyer() && 
          request.resource.data.keys().hasAll(['fullName', 'phone', 'addressLine1', 'city', 'state', 'country', 'isDefault', 'createdAt']) && 
          request.resource.data.fullName is string && 
          request.resource.data.phone is string && 
          request.resource.data.isDefault is bool;
        
        allow update: if isSignedIn() && isOwner(buyerId) && isBuyer();
        
        allow delete: if isSignedIn() && isOwner(buyerId) && isBuyer();
      }
    }
    
    // ========================================
    // WALLET TRANSACTIONS COLLECTION
    // ========================================
    
    match /walletTransactions/{transactionId} {
      // Clients can only read their own transactions.
      // ALL writes (create/update) are handled exclusively by the backend
      // service account via webhook — service accounts bypass these rules entirely.
      allow read: if isSignedIn() && (
        resource.data.userId == getUserId() || 
        isAdmin()
      );
      
      // No client-side writes permitted — backend only
      allow create: if false;
      allow update: if false;
      allow delete: if isAdmin();
    }
    
    // ========================================
    // VENDORS COLLECTION
    // ========================================
    
    match /vendors/{vendorId} {
      allow read: if isSignedIn();
      
      allow create: if isSignedIn() && 
        isOwner(vendorId) && 
        isVendor() && 
        request.resource.data.userId == getUserId() && 
        request.resource.data.keys().hasAll(['userId', 'businessName', 'businessEmail', 'businessPhone', 'createdAt']);
      
      allow update: if isSignedIn() && (
        (isOwner(vendorId) && 
         isVendor() && 
         request.resource.data.userId == resource.data.userId && 
         request.resource.data.get('kycStatus', resource.data.get('kycStatus', 'pending')) == resource.data.get('kycStatus', 'pending') && 
         request.resource.data.get('vendorStatus', resource.data.get('vendorStatus', 'pending')) == resource.data.get('vendorStatus', 'pending') && 
         request.resource.data.get('rating', resource.data.get('rating', 0)) == resource.data.get('rating', 0) && 
         request.resource.data.get('totalSales', resource.data.get('totalSales', 0)) == resource.data.get('totalSales', 0)
        ) || 
        isAdmin()
      );
      
      allow delete: if isAdmin();
    }
    
    // ========================================
    // STORES COLLECTION
    // ========================================
    
    match /stores/{storeId} {
      allow read: if true;
      
      allow create: if isSignedIn() && 
        isVendor() && 
        hasVendorDocument() && 
        request.resource.data.vendorId == getUserId();
      
      allow update: if isSignedIn() && (
        (isVendor() && 
         hasVendorDocument() && 
         resource.data.vendorId == getUserId() && 
         request.resource.data.vendorId == resource.data.vendorId
        ) || 
        isAdmin()
      );
      
      allow delete: if isSignedIn() && (
        (isVendor() && 
         hasVendorDocument() && 
         resource.data.vendorId == getUserId()
        ) || 
        isAdmin()
      );
    }
    
    // ========================================
    // CATEGORIES COLLECTION
    // ========================================
    
    match /categories/{categoryId} {
      allow read: if true;
      
      allow write: if isAdmin();
      
      match /subcategories/{subCategoryId} {
        allow read: if true;
        
        allow write: if isAdmin();
      }
    }
    
    // ========================================
    // PRODUCTS COLLECTION
    // ========================================
    
    match /products/{productId} {
      allow read: if true;
      
      allow create: if isSignedIn() && 
        isVendor() && 
        hasVendorDocument() && 
        request.resource.data.vendorId == getUserId() && 
        request.resource.data.name is string && 
        request.resource.data.name.size() > 0 && 
        request.resource.data.price is number && 
        request.resource.data.price > 0 && 
        request.resource.data.stockQuantity is number && 
        request.resource.data.stockQuantity >= 0 && 
        request.resource.data.categoryId is string && 
        request.resource.data.categoryId.size() > 0;
      
      allow update: if isSignedIn() && (
        (isVendor() && 
         hasVendorDocument() && 
         resource.data.vendorId == getUserId() && 
         request.resource.data.vendorId == resource.data.vendorId
        ) || 
        (isBuyer() && 
         isAccountActive() && 
         request.resource.data.vendorId == resource.data.vendorId && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stockQuantity', 'totalSold', 'updatedAt'])
        ) || 
        isAdmin()
      );
      
      allow delete: if isSignedIn() && (
        (isVendor() && 
         hasVendorDocument() && 
         resource.data.vendorId == getUserId()
        ) || 
        isAdmin()
      );
      
      // Product Variants Subcollection
      match /variants/{variantId} {
        allow read: if true;
        
        allow create: if isSignedIn() && 
          isVendor() && 
          hasVendorDocument() && 
          get(/databases/$(database)/documents/products/$(productId)).data.vendorId == getUserId();
        
        allow update: if isSignedIn() && (
          (isVendor() && 
           hasVendorDocument() && 
           get(/databases/$(database)/documents/products/$(productId)).data.vendorId == getUserId()
          ) || 
          isAdmin()
        );
        
        allow delete: if isSignedIn() && (
          (isVendor() && 
           hasVendorDocument() && 
           get(/databases/$(database)/documents/products/$(productId)).data.vendorId == getUserId()
          ) || 
          isAdmin()
        );
      }
      
      // Product Reviews Subcollection
      match /reviews/{reviewId} {
        allow read: if true;
        
        allow create: if isSignedIn() && isAccountActive();
        
        allow update: if isSignedIn() && (
          resource.data.userId == getUserId() || 
          isAdmin()
        );
        
        allow delete: if isSignedIn() && (
          resource.data.userId == getUserId() || 
          isAdmin()
        );
      }
    }
    
    // ========================================
    // ORDERS COLLECTION
    // ========================================
    
    match /orders/{orderId} {
      allow read: if isSignedIn() && (
        (isBuyer() && resource.data.userId == getUserId()) || 
        isVendor() || 
        isAdmin()
      );
      
      allow create: if isSignedIn() && 
        isBuyer() && 
        isAccountActive() && 
        request.resource.data.userId == getUserId() && 
        request.resource.data.totalAmount > 0 && 
        request.resource.data.paymentStatus in ['pending', 'completed'] && 
        request.resource.data.orderStatus in ['processing', 'pending'] && 
        request.resource.data.keys().hasAll(['orderId', 'userId', 'totalAmount', 'paymentStatus', 'orderStatus', 'createdAt']);
      
      allow update: if isSignedIn() && (
        (isBuyer() && 
         resource.data.userId == getUserId() && 
         request.resource.data.userId == resource.data.userId && 
         request.resource.data.totalAmount == resource.data.totalAmount
        ) || 
        isAdmin() || 
        (isVendor() && 
         request.resource.data.orderStatus in ['processing', 'shipped', 'delivered'])
      );
      
      allow delete: if isAdmin();
      
      // Store Orders Subcollection
      match /storeOrders/{storeOrderId} {
        allow read: if isSignedIn() && (
          (isBuyer() && get(/databases/$(database)/documents/orders/$(orderId)).data.userId == getUserId()) || 
          isVendor() || 
          isAdmin()
        );
        
        allow create: if isSignedIn() && 
          isBuyer() && 
          isAccountActive() && 
          get(/databases/$(database)/documents/orders/$(orderId)).data.userId == getUserId() && 
          request.resource.data.orderId == orderId && 
          request.resource.data.storeId is string && 
          request.resource.data.items is list && 
          request.resource.data.items.size() > 0 && 
          request.resource.data.subtotal > 0 && 
          request.resource.data.total > 0 && 
          request.resource.data.status in ['pending', 'processing'];
        
        allow update: if isSignedIn() && (
          (isVendor() && vendorOwnsStore(resource.data.storeId)) || 
          isAdmin()
        );
        
        allow delete: if isAdmin();
      }
      
      // Order Items Subcollection
      match /items/{itemId} {
        allow read: if isSignedIn() && (
          (isBuyer() && get(/databases/$(database)/documents/orders/$(orderId)).data.userId == getUserId()) || 
          (isVendor() && resource.data.vendorId == getUserId()) || 
          isAdmin()
        );
        
        allow create: if isSignedIn() && 
          isBuyer() && 
          get(/databases/$(database)/documents/orders/$(orderId)).data.userId == getUserId() && 
          request.resource.data.quantity > 0 && 
          request.resource.data.unitPrice > 0 && 
          request.resource.data.subtotal == (request.resource.data.quantity * request.resource.data.unitPrice) && 
          exists(/databases/$(database)/documents/products/$(request.resource.data.productId));
        
        allow update: if isAdmin();
        
        allow delete: if isAdmin();
      }
    }
    
    // ========================================
    // ORDER STATUS COLLECTION
    // ========================================
    
    match /orderStatus/{orderId} {
      allow read: if isSignedIn() && (
        resource.data.userId == getUserId() || 
        isVendor() || 
        isAdmin()
      );
      
      allow create: if isSignedIn() && 
        isBuyer() && 
        isAccountActive() && 
        request.resource.data.userId == getUserId() && 
        request.resource.data.orderId == orderId && 
        request.resource.data.keys().hasAll(['orderId', 'userId', 'status', 'steps', 'createdAt']) && 
        exists(/databases/$(database)/documents/orders/$(orderId));
      
      allow update: if isSignedIn() && (
        isAdmin() || 
        (isVendor() && 
         hasVendorDocument() && 
         request.resource.data.userId == resource.data.userId && 
         request.resource.data.orderId == resource.data.orderId && 
         request.resource.data.status in ['processing', 'shipped', 'delivered', 'cancelled'])
      );
      
      allow delete: if isAdmin();
    }
    
    // ========================================
    // RIDERS COLLECTION
    // ========================================
    
    match /riders/{riderId} {
      allow read: if isSignedIn() && (isOwner(riderId) || isAdmin());
      
      allow create: if isSignedIn() && 
        isOwner(riderId) && 
        isRider() && 
        request.resource.data.userId == getUserId() && 
        request.resource.data.vehicleType in ['bike', 'car'] && 
        request.resource.data.rating == 0 && 
        request.resource.data.isAvailable == true && 
        request.resource.data.keys().hasAll(['userId', 'vehicleType', 'plateNumber', 'rating', 'isAvailable', 'createdAt']);
      
      allow update: if isSignedIn() && (
        (isOwner(riderId) && 
         isRider() && 
         isAccountActive() && 
         request.resource.data.userId == resource.data.userId && 
         request.resource.data.rating == resource.data.rating
        ) || 
        isAdmin()
      );
      
      allow delete: if isAdmin();
    }
    
    // ========================================
    // DELIVERIES COLLECTION
    // ========================================
    
    match /deliveries/{deliveryId} {
      allow read: if isSignedIn() && (
        (isBuyer() && get(/databases/$(database)/documents/orders/$(resource.data.orderId)).data.userId == getUserId()) || 
        (isRider() && resource.data.riderId == getUserId()) || 
        isAdmin()
      );
      
      allow create: if isAdmin();
      
      allow update: if isSignedIn() && (
        (isRider() && 
         resource.data.riderId == getUserId() && 
         isAccountActive() && 
         request.resource.data.riderId == resource.data.riderId && 
         request.resource.data.orderId == resource.data.orderId && 
         request.resource.data.deliveryStatus in ['pending', 'picked_up', 'on_the_way', 'delivered']
        ) || 
        isAdmin()
      );
      
      allow delete: if isAdmin();
    }
    
    // ========================================
    // PAYMENTS COLLECTION
    // ========================================
    
    match /payments/{paymentId} {
      allow read: if isSignedIn() && (
        (isBuyer() && resource.data.buyerId == getUserId()) || 
        isAdmin()
      );
      
      allow create: if isSignedIn() && 
        isBuyer() && 
        isAccountActive() && 
        request.resource.data.buyerId == getUserId() && 
        request.resource.data.amount > 0 && 
        request.resource.data.paymentMethod in ['card', 'transfer', 'wallet'] && 
        request.resource.data.paymentStatus in ['success', 'failed'] && 
        exists(/databases/$(database)/documents/orders/$(request.resource.data.orderId));
      
      allow update: if isAdmin();
      
      allow delete: if isAdmin();
    }
    
    // ========================================
    // NOTIFICATIONS COLLECTION
    // ========================================
    
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (
        resource.data.userId == getUserId() || 
        isAdmin()
      );
      
      allow create: if isSignedIn() && (
        isAdmin() || 
        (isBuyer() && isAccountActive()) || 
        request.resource.data.userId == getUserId()
      );
      
      allow update: if isSignedIn() && (
        (resource.data.userId == getUserId() && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
        ) || 
        isAdmin()
      );
      
      allow delete: if isSignedIn() && (
        resource.data.userId == getUserId() || 
        isAdmin()
      );
    }
    
    // ========================================
    // ANALYTICS COLLECTION
    // ========================================
    
    match /analytics/daily/{date} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    match /analytics/monthly/{monthYear} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    match /analytics/yearly/{year} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    // ========================================
    // BANNERS COLLECTION
    // ========================================
    
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // ========================================
    // PROMOTIONS COLLECTION
    // ========================================
    
    match /promotions/{promotionId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // ========================================
    // REVIEWS COLLECTION (Global)
    // ========================================
    
    match /reviews/{reviewId} {
      allow read: if true;
      
      allow create: if isSignedIn() && 
        isAccountActive() && 
        request.resource.data.userId == getUserId();
      
      allow update: if isSignedIn() && (
        resource.data.userId == getUserId() || 
        isAdmin()
      );
      
      allow delete: if isSignedIn() && (
        resource.data.userId == getUserId() || 
        isAdmin()
      );
    }
    
    // ========================================
    // REPORTS COLLECTION
    // ========================================
    
    match /reports/{reportId} {
      allow read: if isAdmin();
      
      allow create: if isSignedIn() && 
        isAccountActive() && 
        request.resource.data.reportedBy == getUserId();
      
      allow update: if isAdmin();
      
      allow delete: if isAdmin();
    }
    
    // ========================================
    // SETTINGS COLLECTION
    // ========================================
    
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // ========================================
    // SUPPORT TICKETS COLLECTION
    // ========================================
    
    match /supportTickets/{ticketId} {
      allow read: if isSignedIn() && (
        resource.data.userId == getUserId() || 
        isAdmin()
      );
      
      allow create: if isSignedIn() && 
        isAccountActive() && 
        request.resource.data.userId == getUserId();
      
      allow update: if isSignedIn() && (
        resource.data.userId == getUserId() || 
        isAdmin()
      );
      
      allow delete: if isAdmin();
      
      // Support Messages Subcollection
      match /messages/{messageId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/supportTickets/$(ticketId)).data.userId == getUserId() || 
          isAdmin()
        );
        
        allow create: if isSignedIn() && (
          get(/databases/$(database)/documents/supportTickets/$(ticketId)).data.userId == getUserId() || 
          isAdmin()
        );
        
        allow update: if isAdmin();
        
        allow delete: if isAdmin();
      }
    }
    
    // ========================================
    // WISHLIST COLLECTION (Global)
    // ========================================
    
    match /wishlist/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
      
      match /items/{productId} {
        allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
        
        allow create: if isSignedIn() && 
          isOwner(userId) && 
          exists(/databases/$(database)/documents/products/$(productId));
        
        allow delete: if isSignedIn() && isOwner(userId);
      }
    }
    
    // ========================================
    // SEARCH HISTORY COLLECTION
    // ========================================
    
    match /searchHistory/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
      
      match /queries/{queryId} {
        allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
        allow create: if isSignedIn() && isOwner(userId);
        allow delete: if isSignedIn() && isOwner(userId);
      }
    }
    
    // ========================================
    // RECENTLY VIEWED COLLECTION
    // ========================================
    
    match /recentlyViewed/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
      
      match /products/{productId} {
        allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
        
        allow create: if isSignedIn() && 
          isOwner(userId) && 
          exists(/databases/$(database)/documents/products/$(productId));
        
        allow delete: if isSignedIn() && isOwner(userId);
      }
    }
    
    // ========================================
    // VENDOR PAYOUTS COLLECTION
    // ========================================
    
    match /vendorPayouts/{payoutId} {
      allow read: if isSignedIn() && (
        (isVendor() && resource.data.vendorId == getUserId()) || 
        isAdmin()
      );
      
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // ========================================
    // VENDOR EARNINGS COLLECTION
    // ========================================
    
    match /vendorEarnings/{vendorId} {
      allow read: if isSignedIn() && (isOwner(vendorId) || isAdmin());
      
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // ========================================
    // COMMISSION SETTINGS COLLECTION
    // ========================================
    
    match /commissionSettings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // ========================================
    // SHIPPING ZONES COLLECTION
    // ========================================
    
    match /shippingZones/{zoneId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // ========================================
    // TAX SETTINGS COLLECTION
    // ========================================
    
    match /taxSettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // ========================================
    // COUPONS COLLECTION
    // ========================================
    
    match /coupons/{couponId} {
      allow read: if true;
      
      allow create: if isAdmin() || 
        (isVendor() && 
         hasVendorDocument() && 
         request.resource.data.vendorId == getUserId());
      
      allow update: if isAdmin() || 
        (isVendor() && 
         hasVendorDocument() && 
         resource.data.vendorId == getUserId());
      
      allow delete: if isAdmin() || 
        (isVendor() && 
         hasVendorDocument() && 
         resource.data.vendorId == getUserId());
    }
    
    // ========================================
    // FEATURED PRODUCTS COLLECTION
    // ========================================
    
    match /featuredProducts/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // ========================================
    // FLASH SALES COLLECTION
    // ========================================
    
    match /flashSales/{saleId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /products/{productId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }
    
    // ========================================
    // DEFAULT DENY ALL OTHER PATHS
    // ========================================
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
